#!/usr/bin/env python3
"""Second Opinion CLI.

Installs lightweight agent skills and lets one coding agent delegate a scoped
task to another installed coding agent.
"""

from __future__ import annotations

import argparse
import json
import os
import shlex
import shutil
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path
from textwrap import dedent
from typing import Iterable


VERSION = "1.0.2"
SKILL_NAME = "second-opinion"
MARKER = "<!-- Generated by Second Opinion. Managed file. -->"


@dataclass(frozen=True)
class Agent:
    key: str
    display: str
    command: str
    skill_path: str
    compatibility: str
    aliases: tuple[str, ...]
    strengths: str
    consult_args: tuple[str, ...]
    work_args: tuple[str, ...]


AGENTS: dict[str, Agent] = {
    "codex": Agent(
        key="codex",
        display="Codex",
        command="codex",
        skill_path=".agents/skills/second-opinion/SKILL.md",
        compatibility="codex",
        aliases=("openai", "openai-codex"),
        strengths="Repo-wide implementation, careful patching, test triage, and OpenAI/Codex ecosystem work.",
        consult_args=("exec", "--sandbox", "read-only", "--skip-git-repo-check"),
        work_args=("exec", "--sandbox", "workspace-write", "--skip-git-repo-check"),
    ),
    "claude": Agent(
        key="claude",
        display="Claude Code",
        command="claude",
        skill_path=".claude/skills/second-opinion/SKILL.md",
        compatibility="claude-code",
        aliases=("claude-code", "anthropic"),
        strengths="Architecture review, edge-case analysis, refactors, documentation, and reasoning-heavy tasks.",
        consult_args=("-p", "--permission-mode", "plan"),
        work_args=("-p", "--permission-mode", "auto"),
    ),
    "opencode": Agent(
        key="opencode",
        display="OpenCode",
        command="opencode",
        skill_path=".config/opencode/skills/second-opinion/SKILL.md",
        compatibility="opencode",
        aliases=("open-code", "oc"),
        strengths="Model-flexible work across the user's configured providers, quick exploration, and open-source stacks.",
        consult_args=("run", "--agent", "plan"),
        work_args=("run", "--agent", "build"),
    ),
    "grok": Agent(
        key="grok",
        display="Grok Build",
        command="grok",
        skill_path=".grok/skills/second-opinion/SKILL.md",
        compatibility="grok-build",
        aliases=("grok-build", "xai", "xai-grok"),
        strengths="Fast broad exploration, implementation spikes, parallel decomposition, and xAI/Grok-specific work.",
        consult_args=("--no-auto-update",),
        work_args=("--no-auto-update",),
    ),
}


def supports_color() -> bool:
    return sys.stdout.isatty() and not os.environ.get("NO_COLOR")


def style(text: str, color: str) -> str:
    if not supports_color():
        return text
    colors = {
        "cyan": "\033[36m",
        "green": "\033[32m",
        "yellow": "\033[33m",
        "red": "\033[31m",
        "bold": "\033[1m",
        "dim": "\033[2m",
    }
    return f"{colors[color]}{text}\033[0m"


def home_dir() -> Path:
    override = os.environ.get("SECOND_OPINION_HOME")
    return Path(override).expanduser() if override else Path.home()


def resolve_agent(name: str) -> Agent:
    needle = name.strip().lower()
    if needle in AGENTS:
        return AGENTS[needle]
    for agent in AGENTS.values():
        if needle in agent.aliases:
            return agent
    valid = ", ".join(AGENTS)
    raise SystemExit(f"Unknown agent '{name}'. Valid agents: {valid}, auto")


def agent_skill_file(agent: Agent, base_home: Path | None = None) -> Path:
    return (base_home or home_dir()) / agent.skill_path


def detect_agents() -> dict[str, dict[str, object]]:
    result: dict[str, dict[str, object]] = {}
    base_home = home_dir()
    for key, agent in AGENTS.items():
        command_path = shutil.which(agent.command)
        skill_file = agent_skill_file(agent, base_home)
        result[key] = {
            "name": agent.display,
            "command": agent.command,
            "command_path": command_path,
            "detected": bool(command_path),
            "skill_path": str(skill_file),
            "skill_installed": skill_file.exists(),
            "strengths": agent.strengths,
        }
    return result


def print_banner() -> None:
    print(style("Second Opinion", "bold"))
    print(style("mix coding agents as safe, opt-in subagents", "dim"))
    print()


def render_target_notes() -> str:
    rows = []
    for agent in AGENTS.values():
        rows.append(f"- `{agent.key}` ({agent.display}): {agent.strengths}")
    return "\n".join(rows)


def render_skill(agent: Agent) -> str:
    claude_tools = "\nallowed-tools: Bash(second-opinion *)" if agent.key == "claude" else ""
    return dedent(
        f"""\
        ---
        name: second-opinion
        description: Delegate scoped coding tasks, reviews, investigations, or implementation slices to another installed AI coding agent through the Second Opinion CLI.
        license: MIT
        compatibility: {agent.compatibility}{claude_tools}
        ---

        {MARKER}

        # Second Opinion

        Use this skill when the user or task benefits from another coding agent working as a subagent: parallel investigation, code review, implementation planning, debugging, or a narrowly assigned patch.

        ## Workflow

        1. Run `second-opinion status --json` to see which agent CLIs and skill files are available.
        2. Choose a target that is not `{agent.key}` unless the user explicitly asks for recursion or no other agent is available.
        3. Prefer consult mode first. It asks the subagent to inspect, reason, and report without editing files:

           ```bash
           second-opinion ask auto --from {agent.key} --cwd "$PWD" --mode consult -- "Review the current approach and call out risks."
           ```

        4. Use work mode only when the user expects another agent to edit files. Assign a narrow, non-overlapping slice:

           ```bash
           second-opinion ask codex --from {agent.key} --cwd "$PWD" --mode work -- "Implement the parser tests only. Do not touch the API layer."
           ```

        5. Keep doing non-overlapping work while the subagent runs. When it returns, inspect its output, verify any file changes, and integrate the result.

        ## Target Selection

        {render_target_notes()}

        `auto` uses these hints and excludes the calling agent when possible. Use an explicit target when the user asks for a specific agent.

        ## Guardrails

        - Do not ask the subagent to use Second Opinion again unless the user explicitly wants a deeper agent chain.
        - Do not assign two agents to edit the same files at the same time.
        - Do not pass secrets, API keys, private tokens, or unrelated personal data in the task text.
        - If the subagent command fails because the target CLI is missing or unauthenticated, report that directly and continue with your own best effort.
        - Second Opinion only installs skill files and this CLI. It does not change model settings, agent permissions, hooks, MCP servers, or provider credentials.
        """
    )


def managed_write(path: Path, content: str, *, force: bool, dry_run: bool) -> str:
    if path.exists():
        existing = path.read_text(encoding="utf-8", errors="replace")
        if MARKER not in existing and not force:
            return "skipped-existing"
    if dry_run:
        return "would-write"
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content, encoding="utf-8")
    return "installed"


def install_agents(keys: Iterable[str], *, force: bool = False, dry_run: bool = False) -> int:
    rc = 0
    for key in keys:
        agent = resolve_agent(key)
        path = agent_skill_file(agent)
        status = managed_write(path, render_skill(agent), force=force, dry_run=dry_run)
        label = f"{agent.display:<12}"
        if status == "installed":
            print(f"{style('installed', 'green')} {label} {path}")
        elif status == "would-write":
            print(f"{style('dry-run', 'yellow')}   {label} {path}")
        elif status == "skipped-existing":
            print(f"{style('skipped', 'yellow')}   {label} {path}")
            print("             existing file is not managed by Second Opinion; use --force to replace it")
            rc = 1
    return rc


def uninstall_agents(keys: Iterable[str], *, dry_run: bool = False) -> int:
    rc = 0
    for key in keys:
        agent = resolve_agent(key)
        path = agent_skill_file(agent)
        label = f"{agent.display:<12}"
        if not path.exists():
            print(f"{style('missing', 'dim')}   {label} {path}")
            continue
        existing = path.read_text(encoding="utf-8", errors="replace")
        if MARKER not in existing:
            print(f"{style('skipped', 'yellow')}   {label} {path}")
            print("             file is not managed by Second Opinion; remove it manually if intended")
            rc = 1
            continue
        if dry_run:
            print(f"{style('dry-run', 'yellow')}   {label} remove {path}")
        else:
            path.unlink()
            try:
                path.parent.rmdir()
            except OSError:
                pass
            print(f"{style('removed', 'green')}   {label} {path}")
    return rc


def default_install_targets() -> list[str]:
    detected = detect_agents()
    targets = [key for key, info in detected.items() if info["detected"]]
    return targets or list(AGENTS)


def interactive_targets() -> list[str]:
    detected = detect_agents()
    print_banner()
    print("Detected agents:")
    for index, (key, info) in enumerate(detected.items(), start=1):
        status = "found" if info["detected"] else "not found"
        status_color = "green" if info["detected"] else "yellow"
        installed = "skill installed" if info["skill_installed"] else "skill missing"
        print(f"  {index}. {info['name']:<12} {style(status, status_color):<16} {installed}")
    print()
    defaults = default_install_targets()
    default_text = ", ".join(defaults)
    print(f"Default: install skills for {default_text}")
    answer = input("Install default set? [Y/n/custom] ").strip().lower()
    if answer in ("", "y", "yes"):
        return defaults
    if answer in ("n", "no"):
        return []
    selected = answer.replace("custom", "").strip()
    if not selected:
        selected = input("Agents to install (comma separated): ").strip()
    parts = [part.strip().lower() for part in selected.replace(" ", ",").split(",") if part.strip()]
    if "all" in parts:
        return list(AGENTS)
    return [resolve_agent(part).key for part in parts]


def choose_target(caller: str | None, task: str, include_self: bool = False) -> Agent:
    detected = detect_agents()
    available = [key for key, info in detected.items() if info["detected"]]
    if not available:
        raise SystemExit("No supported agent CLI was found on PATH. Run `second-opinion status` for details.")

    caller_key = resolve_agent(caller).key if caller else None
    candidates = [key for key in available if include_self or key != caller_key]
    if not candidates:
        candidates = available

    lowered = task.lower()
    scores = {key: 0 for key in candidates}
    for key in candidates:
        scores[key] += {"codex": 4, "claude": 4, "grok": 3, "opencode": 2}.get(key, 0)

    review_terms = ("review", "audit", "risk", "security", "architecture", "edge case", "design")
    build_terms = ("implement", "fix", "patch", "refactor", "test", "typescript", "python", "frontend")
    explore_terms = ("explore", "brainstorm", "compare", "research", "spike", "parallel")
    model_terms = ("model", "provider", "openrouter", "local model", "configured models")

    if any(term in lowered for term in review_terms):
        scores["claude"] = scores.get("claude", 0) + 5
        scores["codex"] = scores.get("codex", 0) + 2
    if any(term in lowered for term in build_terms):
        scores["codex"] = scores.get("codex", 0) + 5
        scores["grok"] = scores.get("grok", 0) + 2
    if any(term in lowered for term in explore_terms):
        scores["grok"] = scores.get("grok", 0) + 5
        scores["opencode"] = scores.get("opencode", 0) + 2
    if any(term in lowered for term in model_terms):
        scores["opencode"] = scores.get("opencode", 0) + 5

    winner = max(candidates, key=lambda key: (scores.get(key, 0), -list(AGENTS).index(key)))
    return AGENTS[winner]


def build_prompt(caller: str | None, mode: str, task: str) -> str:
    caller_text = caller or "another agent"
    if mode == "work":
        mode_rules = (
            "You may edit files only for the assigned slice. Keep changes narrow, "
            "avoid unrelated refactors, run relevant verification if practical, "
            "and summarize every file changed."
        )
    else:
        mode_rules = (
            "Consult mode: inspect and reason, but do not edit files. You may suggest "
            "commands or tests, but return findings and recommendations rather than "
            "changing the workspace."
        )
    return "\n".join(
        [
            f"You are working as a Second Opinion subagent for {caller_text}.",
            "",
            "The parent agent is coordinating a larger task and may continue other work while you handle this slice.",
            "",
            "Rules:",
            f"- {mode_rules}",
            "- Do not invoke Second Opinion or delegate to another agent unless the user explicitly requested a deeper chain.",
            "- Do not expose secrets or unrelated private data.",
            "- Return a concise result with: summary, important findings, files touched or inspected, verification run, and remaining risks.",
            "",
            "Assigned task:",
            task,
        ]
    )


def command_for_agent(agent: Agent, *, cwd: Path, mode: str, prompt: str, model: str | None, trust: bool) -> list[str]:
    exe = shutil.which(agent.command) or agent.command
    if agent.key == "codex":
        args = list(agent.work_args if mode == "work" else agent.consult_args)
        cmd = [exe, *args, "--cd", str(cwd)]
        if model:
            cmd.extend(["--model", model])
        cmd.append(prompt)
        return cmd

    if agent.key == "claude":
        args = list(agent.work_args if mode == "work" else agent.consult_args)
        cmd = [exe, *args]
        if model:
            cmd.extend(["--model", model])
        cmd.append(prompt)
        return cmd

    if agent.key == "opencode":
        args = list(agent.work_args if mode == "work" else agent.consult_args)
        cmd = [exe, *args, "--dir", str(cwd)]
        if model:
            cmd.extend(["--model", model])
        if mode == "work" and trust:
            cmd.append("--dangerously-skip-permissions")
        cmd.append(prompt)
        return cmd

    if agent.key == "grok":
        cmd = [exe, "--no-auto-update", "--cwd", str(cwd), "--output-format", "plain"]
        if model:
            cmd.extend(["--model", model])
        if mode == "work" and trust:
            cmd.append("--always-approve")
        cmd.extend(["-p", prompt])
        return cmd

    raise AssertionError(f"Unhandled agent {agent.key}")


def task_from_parts(parts: list[str], explicit_task: str | None) -> str:
    if explicit_task:
        return explicit_task.strip()
    cleaned = list(parts)
    if cleaned and cleaned[0] == "--":
        cleaned = cleaned[1:]
    return " ".join(cleaned).strip()


def cmd_status(args: argparse.Namespace) -> int:
    detected = detect_agents()
    if args.json:
        print(json.dumps({"version": VERSION, "agents": detected}, indent=2))
        return 0
    print_banner()
    for key, info in detected.items():
        command = info["command_path"] or "not found"
        skill = "installed" if info["skill_installed"] else "not installed"
        command_color = "green" if info["detected"] else "yellow"
        skill_color = "green" if info["skill_installed"] else "yellow"
        print(f"{info['name']:<12} command: {style(command, command_color)}")
        print(f"{'':<12} skill:   {style(skill, skill_color)}")
        print(f"{'':<12} path:    {info['skill_path']}")
    return 0


def cmd_install(args: argparse.Namespace) -> int:
    if args.home:
        os.environ["SECOND_OPINION_HOME"] = args.home
    if args.all:
        targets = list(AGENTS)
    elif args.agent:
        targets = [resolve_agent(agent).key for agent in args.agent]
    elif args.yes or not sys.stdin.isatty():
        targets = default_install_targets()
    else:
        targets = interactive_targets()
    if not targets:
        print("No skills installed.")
        return 0
    return install_agents(targets, force=args.force, dry_run=args.dry_run)


def cmd_uninstall(args: argparse.Namespace) -> int:
    if args.home:
        os.environ["SECOND_OPINION_HOME"] = args.home
    if args.all:
        targets = list(AGENTS)
    elif args.agent:
        targets = [resolve_agent(agent).key for agent in args.agent]
    else:
        raise SystemExit("Choose --all or at least one --agent.")
    return uninstall_agents(targets, dry_run=args.dry_run)


def cmd_choose(args: argparse.Namespace) -> int:
    task = task_from_parts(args.task_parts, args.task)
    agent = choose_target(args.caller, task, include_self=args.include_self)
    if args.json:
        print(json.dumps({"agent": agent.key, "name": agent.display, "command": agent.command}, indent=2))
    else:
        print(agent.key)
    return 0


def cmd_ask(args: argparse.Namespace) -> int:
    task = task_from_parts(args.task_parts, args.task)
    if not task:
        raise SystemExit("Provide a task after -- or with --task.")
    cwd = Path(args.cwd).expanduser().resolve()
    if not cwd.exists():
        raise SystemExit(f"Working directory does not exist: {cwd}")

    target_name = args.target or "auto"
    if target_name == "auto":
        agent = choose_target(args.caller, task, include_self=args.include_self)
    else:
        agent = resolve_agent(target_name)

    if not shutil.which(agent.command) and not args.dry_run:
        raise SystemExit(f"{agent.display} CLI not found on PATH as `{agent.command}`.")

    prompt = build_prompt(args.caller, args.mode, task)
    cmd = command_for_agent(agent, cwd=cwd, mode=args.mode, prompt=prompt, model=args.model, trust=args.trust)

    if args.dry_run:
        print(shlex.join(cmd))
        return 0

    print(style(f"Second Opinion -> {agent.display} ({args.mode})", "cyan"), file=sys.stderr)
    timeout = None if args.timeout == 0 else args.timeout
    try:
        completed = subprocess.run(
            cmd,
            cwd=str(cwd),
            stdin=subprocess.DEVNULL,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            timeout=timeout,
            check=False,
        )
    except subprocess.TimeoutExpired:
        raise SystemExit(f"{agent.display} timed out after {args.timeout} seconds.")

    if completed.stdout:
        print(completed.stdout, end="" if completed.stdout.endswith("\n") else "\n")
    if completed.stderr:
        print(completed.stderr, file=sys.stderr, end="" if completed.stderr.endswith("\n") else "\n")
    return completed.returncode


def cmd_commands(_: argparse.Namespace) -> int:
    print("Main CLI:")
    print("  curl -fsSL https://second-opinion.ssh.codes/install.sh | bash")
    print()
    print("Install for detected agents:")
    print("  curl -fsSL https://second-opinion.ssh.codes/install.sh | bash -s -- --yes")
    print()
    print("Install for every supported agent:")
    print("  curl -fsSL https://second-opinion.ssh.codes/install.sh | bash -s -- --all --yes")
    print()
    print("Install a specific agent skill:")
    for key in AGENTS:
        print(f"  curl -fsSL https://second-opinion.ssh.codes/install.sh | bash -s -- --agent {key} --yes")
    print()
    print("Install on a remote machine over SSH:")
    print("  ssh dev@server 'curl -fsSL https://second-opinion.ssh.codes/install.sh | bash -s -- --all --yes'")
    print()
    print("Delegate from an agent:")
    print('  second-opinion ask auto --from codex --cwd "$PWD" --mode consult -- "Review this change."')
    return 0


def cmd_doctor(_: argparse.Namespace) -> int:
    rc = cmd_status(argparse.Namespace(json=False))
    bin_path = shutil.which("second-opinion")
    print()
    if bin_path:
        print(f"{style('ok', 'green')} second-opinion is on PATH: {bin_path}")
    else:
        print(f"{style('warn', 'yellow')} second-opinion is not on PATH. Add ~/.local/bin to PATH.")
        rc = 1
    return rc


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="second-opinion",
        description="Install and use AI coding agents as opt-in subagents for each other.",
    )
    parser.add_argument("--version", action="version", version=f"%(prog)s {VERSION}")
    sub = parser.add_subparsers(dest="command", required=True)

    status = sub.add_parser("status", help="Show detected agents and installed skills.")
    status.add_argument("--json", action="store_true", help="Emit machine-readable JSON.")
    status.set_defaults(func=cmd_status)

    install = sub.add_parser("install", help="Install Second Opinion skills.")
    install.add_argument("--agent", action="append", choices=[*AGENTS.keys(), "claude-code", "grok-build"], help="Install one agent skill. Repeatable.")
    install.add_argument("--all", action="store_true", help="Install all supported agent skills.")
    install.add_argument("--yes", "-y", action="store_true", help="Skip interactive selection and install detected agents.")
    install.add_argument("--force", action="store_true", help="Replace an existing non-generated skill file.")
    install.add_argument("--dry-run", action="store_true", help="Show what would be written.")
    install.add_argument("--home", help="Override home directory, useful for tests.")
    install.set_defaults(func=cmd_install)

    uninstall = sub.add_parser("uninstall", help="Remove Second Opinion managed skills.")
    uninstall.add_argument("--agent", action="append", choices=[*AGENTS.keys(), "claude-code", "grok-build"], help="Remove one agent skill. Repeatable.")
    uninstall.add_argument("--all", action="store_true", help="Remove all managed skill files.")
    uninstall.add_argument("--dry-run", action="store_true", help="Show what would be removed.")
    uninstall.add_argument("--home", help="Override home directory, useful for tests.")
    uninstall.set_defaults(func=cmd_uninstall)

    choose = sub.add_parser("choose", help="Choose the best installed subagent for a task.")
    choose.add_argument("--from", dest="caller", help="Calling agent to exclude when possible.")
    choose.add_argument("--include-self", action="store_true", help="Allow choosing the calling agent.")
    choose.add_argument("--task", help="Task text.")
    choose.add_argument("--json", action="store_true")
    choose.add_argument("task_parts", nargs="*")
    choose.set_defaults(func=cmd_choose)

    ask = sub.add_parser("ask", help="Run another agent as a scoped subagent.")
    ask.add_argument("target", nargs="?", help="Target agent: auto, codex, claude, opencode, or grok.", default="auto")
    ask.add_argument("--from", dest="caller", help="Calling agent name.")
    ask.add_argument("--cwd", default=".", help="Workspace directory for the subagent.")
    ask.add_argument("--mode", choices=("consult", "work"), default="consult", help="consult is read-only by prompt/policy; work may edit.")
    ask.add_argument("--model", help="Pass a model override to the target CLI when supported.")
    ask.add_argument("--timeout", type=int, default=1800, help="Seconds before killing the subagent. Use 0 for no timeout.")
    ask.add_argument("--task", help="Task text.")
    ask.add_argument("--dry-run", action="store_true", help="Print the underlying agent command.")
    ask.add_argument("--include-self", action="store_true", help="Allow auto to choose the caller if needed.")
    ask.add_argument("--trust", action="store_true", help="Allow high-permission work-mode flags for agents that support them.")
    ask.add_argument("task_parts", nargs="*")
    ask.set_defaults(func=cmd_ask)

    commands = sub.add_parser("commands", help="Print copy-paste install and usage commands.")
    commands.set_defaults(func=cmd_commands)

    doctor = sub.add_parser("doctor", help="Run basic installation checks.")
    doctor.set_defaults(func=cmd_doctor)
    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    return int(args.func(args))


if __name__ == "__main__":
    raise SystemExit(main())
